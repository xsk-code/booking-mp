<!--pages/booking-detail/booking-detail.wxml-->
<view class="container">
  <!-- 状态头部 -->
  <view class="status-header" wx:if="{{booking}}">
    <view class="status-text status-{{booking.status}}">{{booking.statusText}}</view>
    <view class="status-desc" wx:if="{{booking.status === 'pending'}}">
      等待管理员审核中...
    </view>
    <view class="status-desc" wx:if="{{booking.status === 'approved'}}">
      预约已通过，请按时到场
    </view>
    <view class="status-desc" wx:if="{{booking.status === 'rejected'}}">
      <text wx:if="{{booking.reject_reason}}">拒绝原因：{{booking.reject_reason}}</text>
      <text wx:else>预约被拒绝</text>
    </view>
    <view class="status-desc" wx:if="{{booking.status === 'cancelled'}}">
      预约已取消
    </view>
  </view>

  <!-- 预约信息 -->
  <view class="info-section" wx:if="{{booking}}">
    <view class="section-title">预约信息</view>
    
    <view class="info-item">
      <text class="info-label">预约资源</text>
      <text class="info-value">{{booking.resource_name}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">预约日期</text>
      <text class="info-value">{{booking.booking_date}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">预约时段</text>
      <text class="info-value">{{booking.start_time}} - {{booking.end_time}}</text>
    </view>
    
    <view class="info-item" wx:if="{{booking.guest_count}}">
      <text class="info-label">预约人数</text>
      <text class="info-value">{{booking.guest_count}}人</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">联系人</text>
      <text class="info-value">{{booking.contact_name}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">联系电话</text>
      <text class="info-value">{{booking.contact_phone}}</text>
    </view>
    
    <view class="info-item" wx:if="{{booking.remark}}">
      <text class="info-label">备注</text>
      <text class="info-value">{{booking.remark}}</text>
    </view>
  </view>

  <!-- 审核信息 -->
  <view class="info-section" wx:if="{{booking && (booking.reviewed_at || booking.reviewed_by)}}">
    <view class="section-title">审核信息</view>
    
    <view class="info-item" wx:if="{{booking.reviewed_at}}">
      <text class="info-label">审核时间</text>
      <text class="info-value">{{booking.reviewed_at}}</text>
    </view>
    
    <view class="info-item" wx:if="{{booking.reject_reason}}">
      <text class="info-label">拒绝原因</text>
      <text class="info-value">{{booking.reject_reason}}</text>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-actions" wx:if="{{booking && (booking.status === 'pending' || booking.status === 'approved')}}">
    <view class="action-btn cancel" wx:if="{{booking.status === 'pending' || booking.status === 'approved'}}" 
          bindtap="cancelBooking">
      取消预约
    </view>
    <view class="action-btn primary" wx:if="{{booking.status === 'approved'}}" 
          bindtap="contactAdmin">
      联系场地
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>
</view>
