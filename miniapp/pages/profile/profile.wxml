<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="profile-header">
    <view class="user-info" wx:if="{{isLoggedIn && userInfo}}">
      <image class="avatar" src="{{userInfo.avatar_url || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="user-detail">
        <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
      </view>
    </view>
    
    <view class="login-prompt" wx:else bindtap="handleLogin">
      <image class="avatar placeholder" src="/assets/images/default-avatar.png" mode="aspectFill" />
      <view class="login-text">点击登录</view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToMyBookings">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的预约</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="goToMyVenues">
      <text class="menu-icon">🏢</text>
      <text class="menu-text">我的场地</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="handleLogout">退出登录</view>
  </view>

  <view class="version-info">
    <text>版本 v1.0.0</text>
  </view>
</view>
