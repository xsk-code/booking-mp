/* pages/my-venues/my-venues.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.create-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1989fa 0%, #1677de 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.create-icon {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 300;
}

.create-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 500;
  margin-left: 24rpx;
}

.venue-list-section {
  
}

.section-title {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.venue-list {
  display: flex;
  flex-direction: column;
}

.venue-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.venue-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.venue-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.venue-code {
  background: linear-gradient(135deg, #e8f4ff 0%, #d0e8ff 100%);
  color: #1989fa;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-family: monospace;
  font-weight: 500;
}

.venue-info {
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
}

.venue-footer {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.enter-text {
  font-size: 26rpx;
  color: #1989fa;
}

.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
  text-align: center;
}

.create-btn {
  background: linear-gradient(135deg, #1989fa 0%, #1677de 100%);
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
}

.create-btn-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
}

.loading-section {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}
