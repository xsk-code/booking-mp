<!--pages/booking-result/booking-result.wxml-->
<view class="container">
  <view class="result-container">
    <!-- 成功状态 -->
    <view class="result-content" wx:if="{{isSuccess}}">
      <view class="success-icon">✓</view>
      <view class="result-title">预约提交成功</view>
      <view class="result-desc">您的预约已提交，请等待管理员审核</view>
      <view class="result-tip">审核结果将通过微信订阅消息通知您</view>
    </view>

    <!-- 失败状态 -->
    <view class="result-content" wx:if="{{!isSuccess}}">
      <view class="fail-icon">✗</view>
      <view class="result-title">预约提交失败</view>
      <view class="result-desc">{{errorMessage}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="btn primary" bindtap="goToMyBookings">查看我的预约</view>
      <view class="btn secondary" bindtap="goToHome">返回首页</view>
    </view>
  </view>
</view>
