/* pages/booking-result/booking-result.wxss */

.container {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-container {
  width: 100%;
  padding: 48rpx;
  box-sizing: border-box;
}

.result-content {
  text-align: center;
  margin-bottom: 80rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background-color: #52c41a;
  border-radius: 50%;
  color: #ffffff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
}

.fail-icon {
  width: 120rpx;
  height: 120rpx;
  background-color: #ee0a24;
  border-radius: 50%;
  color: #ffffff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.result-tip {
  font-size: 24rpx;
  color: #999999;
}

.action-buttons {
  display: flex;
  flex-direction: column;
}

.btn {
  padding: 24rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}

.btn.primary {
  background-color: #1989fa;
  color: #ffffff;
}

.btn.secondary {
  background-color: #ffffff;
  color: #1989fa;
  border: 2rpx solid #1989fa;
}

.btn:last-child {
  margin-bottom: 0;
}
