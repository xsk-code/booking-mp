/* pages/index/index.wxss */

/* 搜索栏 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  margin-right: 16rpx;
  font-size: 28rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

/* 场地列表 */
.venue-list {
  margin-bottom: 20rpx;
}

.venue-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.venue-image {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.venue-img {
  width: 100%;
  height: 100%;
}

.venue-info {
  padding: 24rpx;
}

.venue-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.venue-address,
.venue-time,
.venue-contact {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666666;
}

.venue-address:last-child,
.venue-time:last-child,
.venue-contact:last-child {
  margin-bottom: 0;
}

.icon {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.address-text,
.time-text,
.phone-text {
  flex: 1;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载中 */
.loading-container {
  padding: 100rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}
