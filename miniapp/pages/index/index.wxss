/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e4e8ec 100%);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.header-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999999;
}

.search-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.search-box {
  margin-bottom: 32rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input-wrapper input {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.placeholder {
  color: #bbbbbb;
}

.search-btn {
  background: linear-gradient(135deg, #1989fa 0%, #1677de 100%);
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  margin-left: 16rpx;
}

.search-btn.loading {
  opacity: 0.7;
}

.search-btn-text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
}

.scan-section {
  display: flex;
  justify-content: center;
}

.scan-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 48rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 20rpx;
  border: 2rpx dashed #1989fa;
}

.scan-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.scan-text {
  font-size: 28rpx;
  color: #1989fa;
  font-weight: 500;
}

.recent-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.clear-btn {
  font-size: 24rpx;
  color: #999999;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.recent-info {
  flex: 1;
}

.recent-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.recent-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.recent-code {
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  font-family: monospace;
}

.recent-address {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}
