<!--pages/index/index.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <input type="text" placeholder="搜索场地名称" value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>
  </view>

  <!-- 场地列表 -->
  <view class="venue-list" wx:if="{{venueList.length > 0}}">
    <view class="venue-card" wx:for="{{venueList}}" wx:key="id" bindtap="goToVenueDetail" data-id="{{item.id}}">
      <view class="venue-image">
        <image src="{{item.cover_image_url || '/assets/images/default-venue.png'}}" mode="aspectFill" class="venue-img" />
      </view>
      <view class="venue-info">
        <view class="venue-name">{{item.name}}</view>
        <view class="venue-address">
          <text class="icon">📍</text>
          <text class="address-text">{{item.address || '暂无地址'}}</text>
        </view>
        <view class="venue-time">
          <text class="icon">🕐</text>
          <text class="time-text">{{item.business_start}} - {{item.business_end}}</text>
        </view>
        <view class="venue-contact" wx:if="{{item.contact_phone}}">
          <text class="icon">📞</text>
          <text class="phone-text">{{item.contact_phone}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && venueList.length === 0}}">
    <image src="/assets/images/empty-venue.png" class="empty-icon" mode="aspectFit" />
    <text class="empty-text">暂无可用场地</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>
</view>
