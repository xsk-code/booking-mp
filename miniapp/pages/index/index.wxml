<!--pages/index/index.wxml-->
<view class="container">
  <view class="header-section">
    <view class="header-title">🏢 预约小程序</view>
    <view class="header-subtitle">扫描场地二维码或输入场地码进入</view>
  </view>

  <view class="search-section">
    <view class="search-box">
      <view class="search-input-wrapper">
        <text class="search-icon">🔍</text>
        <input 
          type="text" 
          placeholder="输入场地码（如：QT8A2F）" 
          value="{{venueCode}}" 
          bindinput="onVenueCodeInput"
          placeholder-class="placeholder"
          maxlength="16"
        />
        <view class="search-btn" bindtap="onSearch" wx:if="{{!searchLoading}}">
          <text class="search-btn-text">搜索</text>
        </view>
        <view class="search-btn loading" wx:if="{{searchLoading}}">
          <text class="search-btn-text">搜索中...</text>
        </view>
      </view>
    </view>

    <view class="scan-section">
      <view class="scan-btn" bindtap="onScanCode">
        <view class="scan-icon">📷</view>
        <text class="scan-text">扫描场地二维码</text>
      </view>
    </view>
  </view>

  <view class="recent-section" wx:if="{{hasRecentVenues}}">
    <view class="section-header">
      <text class="section-title">最近访问</text>
      <text class="clear-btn" bindtap="clearRecentVenues">清除</text>
    </view>
    
    <view class="recent-list">
      <view 
        class="recent-item" 
        wx:for="{{recentVenues}}" 
        wx:key="id"
        bindtap="onRecentVenueTap"
        data-id="{{item.id}}"
      >
        <view class="recent-icon">📍</view>
        <view class="recent-info">
          <view class="recent-name">{{item.name}}</view>
          <view class="recent-meta">
            <text class="recent-code">{{item.venue_code}}</text>
            <text class="recent-address" wx:if="{{item.address}}">{{item.address}}</text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="empty-section" wx:if="{{!hasRecentVenues}}">
    <view class="empty-icon">🏠</view>
    <view class="empty-text">暂无访问记录</view>
    <view class="empty-hint">扫描场地二维码或输入场地码开始预约</view>
  </view>
</view>
