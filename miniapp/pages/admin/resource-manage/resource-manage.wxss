/* pages/admin/resource-manage/resource-manage.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.resource-list {
  
}

.resource-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.resource-info {
  flex: 1;
}

.resource-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.resource-meta {
  display: flex;
}

.meta-item {
  font-size: 24rpx;
  color: #999999;
  margin-right: 20rpx;
}

.resource-status {
  
}

.status-text {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-text.active {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-text.disabled {
  background-color: #f5f5f5;
  color: #999999;
}

.empty-state {
  padding: 100rpx 0;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.add-btn {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  background-color: #1989fa;
  color: #ffffff;
  text-align: center;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: bold;
}
