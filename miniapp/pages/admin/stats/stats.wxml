<!--pages/admin/stats/stats.wxml-->
<view class="container">
  <view class="stats-overview">
    <view class="overview-card">
      <view class="stat-value">{{stats.totalBookings}}</view>
      <view class="stat-label">总预约数</view>
    </view>
    <view class="overview-card">
      <view class="stat-value">{{stats.pendingCount}}</view>
      <view class="stat-label">待审核</view>
    </view>
    <view class="overview-card">
      <view class="stat-value">{{stats.approvedRate}}%</view>
      <view class="stat-label">通过率</view>
    </view>
  </view>
  
  <view class="chart-section">
    <view class="section-title">预约趋势</view>
    <view class="chart-placeholder">
      <text>图表功能开发中...</text>
    </view>
  </view>
  
  <view class="chart-section">
    <view class="section-title">热门资源</view>
    <view class="resource-list">
      <view class="resource-item" wx:for="{{stats.topResources}}" wx:key="name">
        <view class="resource-name">{{item.name}}</view>
        <view class="resource-count">{{item.count}}次</view>
      </view>
    </view>
  </view>
</view>
