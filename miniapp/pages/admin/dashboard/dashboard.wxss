/* pages/admin/dashboard/dashboard.wxss */

/* 统计概览 */
.stats-section {
  background: linear-gradient(135deg, #1989fa 0%, #1890ff 100%);
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  margin-bottom: 24rpx;
}

.stats-row:last-child {
  margin-bottom: 0;
}

.stat-item {
  flex: 1;
  text-align: center;
  position: relative;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-badge {
  position: absolute;
  top: -8rpx;
  right: 40rpx;
  background-color: #ee0a24;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 功能菜单 */
.menu-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
}

.menu-header {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-icon.pending {
  background-color: #fff7e6;
}

.menu-icon.calendar {
  background-color: #e6f7ff;
}

.menu-icon.resource {
  background-color: #f6ffed;
}

.menu-icon.settings {
  background-color: #f0f0f0;
}

.menu-icon.chart {
  background-color: #fff0f6;
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999999;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

/* 最近预约 */
.recent-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #1989fa;
}

.booking-list {
  padding: 0 32rpx;
}

.booking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.booking-item:last-child {
  border-bottom: none;
}

.booking-info {
  flex: 1;
}

.booking-name {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.booking-time {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.booking-contact {
  font-size: 24rpx;
  color: #999999;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.status-pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background-color: #e6f7ff;
  color: #1890ff;
}

.empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}
