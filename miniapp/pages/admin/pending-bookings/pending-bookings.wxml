<!--pages/admin/pending-bookings/pending-bookings.wxml-->
<view class="container">
  <view class="booking-list" wx:if="{{bookingList.length > 0}}">
    <view class="booking-card" wx:for="{{bookingList}}" wx:key="id">
      <view class="booking-header">
        <view class="resource-name">{{item.resource_name}}</view>
        <view class="status-tag status-pending">待审核</view>
      </view>
      <view class="booking-info">
        <view class="info-item">
          <text class="info-label">预约时间</text>
          <text class="info-value">{{item.booking_date}} {{item.start_time}}-{{item.end_time}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">联系人</text>
          <text class="info-value">{{item.contact_name}} {{item.contact_phone}}</text>
        </view>
        <view class="info-item" wx:if="{{item.guest_count}}">
          <text class="info-label">人数</text>
          <text class="info-value">{{item.guest_count}}人</text>
        </view>
        <view class="info-item" wx:if="{{item.remark}}">
          <text class="info-label">备注</text>
          <text class="info-value">{{item.remark}}</text>
        </view>
      </view>
      <view class="booking-actions">
        <view class="action-btn reject" bindtap="rejectBooking" data-id="{{item.id}}">拒绝</view>
        <view class="action-btn approve" bindtap="approveBooking" data-id="{{item.id}}">通过</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && bookingList.length === 0}}">
    <text class="empty-text">暂无待审核预约</text>
  </view>

  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>
</view>
