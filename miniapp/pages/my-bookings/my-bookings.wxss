/* pages/my-bookings/my-bookings.wxss */

/* 标签切换 */
.tabs-scroll {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.tabs {
  display: flex;
  padding: 0 24rpx;
}

.tab-item {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
  white-space: nowrap;
}

.tab-item.active {
  color: #1989fa;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #1989fa;
  border-radius: 2rpx;
}

/* 预约列表 */
.booking-list {
  padding: 0 20rpx;
}

.booking-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.booking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.resource-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-rejected {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.status-cancelled {
  background-color: #f5f5f5;
  color: #999999;
}

/* 预约信息 */
.booking-info {
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

/* 操作按钮 */
.booking-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.action-btn {
  padding: 12rpx 32rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
}

.action-btn.cancel {
  background-color: #fff1f0;
  color: #ff4d4f;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.empty-action {
  padding: 16rpx 48rpx;
  background-color: #1989fa;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 加载中 */
.loading-container {
  padding: 100rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}
